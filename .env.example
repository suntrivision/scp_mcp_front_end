# Optional: persist "Create Agents" in Supabase (see supabase/migrations/001_query_agents.sql)

VITE_SUPABASE_URL=https://your-project.supabase.co

VITE_SUPABASE_ANON_KEY=your-anon-key



# Optional: Anthropic Messages proxy (api/anthropic-messages) — only if something still calls it

ANTHROPIC_API_KEY=

# VITE_ANTHROPIC_KEY=



# Tally + Express API (chart of accounts, trial balance, companies). Required for Vercel/static builds:
# set at build time so the browser calls your Node server (CDN has no /api).
# Example: VITE_API_BASE_URL=https://your-api.onrender.com
#
# Vercel — prefer VITE_API_BASE_URL at build time to avoid serverless timeouts on Tally routes.
# VITE_API_BASE_URL=https://tally-mcp-api.onrender.com
#
# If you use the Vercel proxy instead, set (server env on Vercel):
# TALLY_BACKEND_URL=https://tally-mcp-api.onrender.com
# Optional: fail fetch before platform kills the function (ms). See DEPLOY_VERCEL.md.
# TALLY_PROXY_FETCH_MS=9500
#
# Render / Linux API: default TALLY_MCP_ROOT is ./tally-prime (vendored dist/tally.mjs).
# TallyPrime XML server must be reachable from that host (set TALLY_HOST / TALLY_PORT).
# Default port is 9000; if something else uses 9000, pick another port in Tally (F1 → Settings →
# Connectivity) and set TALLY_PORT to the same value here and on Render.
# TALLY_HOST=
# TALLY_PORT=9000
#
# Browser UI can append ?tallyHost=&tallyPort= on /api/* Tally routes. Set to false on public APIs (e.g. Render).
# TALLY_ALLOW_CLIENT_OVERRIDE=true
# Optional comma list of extra allowed hosts when override is true (localhost/127.0.0.1 always allowed).
# TALLY_ALLOWED_HOSTS=
# Local dev: leave unset; Vite proxies /api to port 8787.

# VITE_API_BASE_URL=

# Y3 backend (AI Reporting Agent, Dynamic Inventory Shortage, Exception Agent)

# Local: npm run dev runs server/index.mjs — Claude CLI + Y3 MCP on the same machine.

# Vercel: set to your public backend base URL; serverless routes under /api/frepple/* proxy there.

# FREPPLE_BACKEND_URL=https://agenticshop-frepple-numm.onrender.com

# That backend must expose POST /api/frepple/query with mode inventory_shortage (see server/index.mjs, server/BACKEND_INVENTORY_SHORTAGE.md for MCPSCP).



# Optional: Bearer for Anthropic remote MCP proxy only (rare)

# FREPPLE_MCP_AUTHORIZATION_TOKEN=

# FREPPLE_TOKEN=


