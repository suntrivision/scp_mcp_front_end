# Optional: persist "Create Agents" in Supabase (see supabase/migrations/001_query_agents.sql)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Dynamic Inventory Shortage Agent — server-side Anthropic key (never use VITE_ for the API key)
# Local: loaded by server/index.mjs via dotenv. Vercel: add ANTHROPIC_API_KEY as a Sensitive env var.
ANTHROPIC_API_KEY=
# Optional legacy fallback for local dev only (same key as above is fine):
# VITE_ANTHROPIC_KEY=
# Optional — MCP URL (safe to expose to the client):
# VITE_FREPPLE_MCP_URL=https://agenticshop-frepple-numm.onrender.com
