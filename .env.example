# Optional: persist "Create Agents" in Supabase (see supabase/migrations/001_query_agents.sql)

VITE_SUPABASE_URL=https://your-project.supabase.co

VITE_SUPABASE_ANON_KEY=your-anon-key



# Optional: Anthropic Messages proxy (api/anthropic-messages) — only if something still calls it

ANTHROPIC_API_KEY=

# VITE_ANTHROPIC_KEY=



# Y3 backend (AI Reporting Agent, Dynamic Inventory Shortage, Exception Agent)

# Local: npm run dev runs server/index.mjs — Claude CLI + Y3 MCP on the same machine.

# Vercel: set to your public backend base URL; serverless routes under /api/frepple/* proxy there.

# FREPPLE_BACKEND_URL=https://agenticshop-frepple-numm.onrender.com

# That backend must expose POST /api/frepple/query with mode inventory_shortage (see server/index.mjs) — same stack as Reporting.



# Optional: Bearer for Anthropic remote MCP proxy only (rare)

# FREPPLE_MCP_AUTHORIZATION_TOKEN=

# FREPPLE_TOKEN=


