# Optional: persist "Create Agents" in Supabase (see supabase/migrations/001_query_agents.sql)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Dynamic Inventory Shortage Agent — server-side Anthropic key (never use VITE_ for the API key)
# Local: loaded by server/index.mjs via dotenv. Vercel: add ANTHROPIC_API_KEY as a Sensitive env var.
ANTHROPIC_API_KEY=
# Optional legacy fallback for local dev only (same key as above is fine):
# VITE_ANTHROPIC_KEY=
# frePPLe backend base (used by /api/frepple/* on Vercel and as MCP URL when VITE_FREPPLE_MCP_URL is unset)
# FREPPLE_BACKEND_URL=https://your-public-backend.example.com
# Optional: override MCP connector URL only (otherwise same as FREPPLE_BACKEND_URL)
# VITE_FREPPLE_MCP_URL=https://your-mcp-host.example.com/sse
# If the MCP server requires OAuth/Bearer, set this only on the server (never VITE_*):
# FREPPLE_MCP_AUTHORIZATION_TOKEN=
